:{"line":7,"column":1},"end":{"line":7,"column":1}},"key":"JHFcf5IIRG"},{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":15,"column":1}},"children":[{"type":"text","value":"地震体波是在地球内部传播的机械波。与光类似，地震波在遇到介质界面时也会出现反射、\n折射和衍射等现象。与光不同的是，地震波既有横波（S 波）又有纵波（P 波），\n地震波在介质界面发生反射或折射时还会发生波的转换，即横波可以转换为纵波，纵波也\n可以转换为横波。地震波在地球内部传播时，会遇到地球内部的多个界面，并在界面处\n发生反射、折射以及横波/纵波的互相转换。因而，震源激发的地震波在地球内部传播时\n会有很多可能的传播路径，沿着不同路径传播的地震波走时也不同，在观测记录上表现为\n不同特征的信号，称之为地震震相（seismic phase）。","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"LkQsL2xfJd"}],"key":"G13msRYTnF"},{"type":"heading","depth":2,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"地球圈层结构","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"IibahoB2Cj"}],"identifier":"id","label":"地球圈层结构","html_id":"id","implicit":true,"key":"itlxQDd8v1"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"在介绍地震震相之间，有必要先介绍地球的分层结构。","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"QeMkm2uIiL"}],"key":"FzbJQ82uvX"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"固体地球的半径约为 6371 公里，具有明显的圈层结构。地球从外到内可以分为如下几个圈层：","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"YsuafpSln0"}],"key":"gyijdnxT5U"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":23,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"地壳（crust）：地球的最表层，大陆地壳的平均厚度为 30-50 km，大洋地壳的平均厚度约为 6 km","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"vhY1QxBZDX"}],"key":"wOS8BeCfeE"}],"key":"HMNDi9Sosc"},{"type":"listItem","spread":tru
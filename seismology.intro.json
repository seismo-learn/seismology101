e":31,"column":1},"end":{"line":31,"column":1}},"key":"RsLXongMg2"}],"key":"yhWv7kQgHz"},{"type":"container","kind":"figure","children":[{"type":"image","url":"/seismology101/build/seismology-overview-1c7d035e9da8af0a5def3275b8e9ff32.jpg","alt":"地震激发的地震波路径和波形","width":"95%","align":"center","key":"boshDohf5r","urlSource":"seismology-overview.jpg"},{"type":"caption","children":[{"type":"paragraph","position":{"start":{"line":45,"column":1},"end":{"line":46,"column":1}},"children":[{"type":"text","value":"1994 年 1 月 17 日，美国加利福尼亚州 Northridge 地震激发的地震波的传播路径和观测波形。\n引自 ","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"Hw5Btjrt8X"},{"type":"link","url":"https://www.iris.edu/hq/inclass/fact-sheet/exploring_earth_using_seismology","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"children":[{"type":"text","value":"Exploring the Earth Using Seismology","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"tNw8B3I3jg"}],"urlSource":"https://www.iris.edu/hq/inclass/fact-sheet/exploring_earth_using_seismology","key":"rvKIXWSpW6"},{"type":"text","value":"。","position":{"start":{"line":45,"column":1},"end":{"line":45,"column":1}},"key":"myuiIRgxKS"}],"key":"ikGHF80Wa3"}],"key":"xTP961fSSF"}],"enumerator":"1","key":"gpVvCe0hki"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"1994 年 1 月 17 日，美国加利福尼亚州 Northridge 附近发生了 ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"Oo8bBUSDNT"},{"type":"link","url":"https://earthquake.usgs.gov/earthquakes/eventpage/ci3144585/","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"6.7 级地震","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"BhecYYo1gL"}],"urlSource":"https://earthquake.usgs.gov/earthquakes/eventpage/ci3144585/","key":"i4OdX5EZ3R"},{"type":"text","value":"，\n其释放出的能量相当于将近 20 亿千克高爆炸药。该地震产生的地震波经过地球内部传播后，\n被世界各地的地震台站记录到。上图左侧展示了不同地震波在地下的传播路径，右侧展示了地震波到达\n地表后，全球台站记录到的地表振动，即地震图。","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"LUC9BN0vNP"}],"key":"GVj2geNMqx"},{"type":"paragraph","position":{"start":{"line":54,"column":1},"end":{"line":57,"column":1}},"children":[{"type":"text","value":"因此，地震图携带了震源和地球内部结构的信息。地震学家正是通过分析地震图来研究产生这些振动的\n震源以及地球内部结构。地球平均半径约为 6371 公里，现在很难直接观测地球内部，\n历史上最深的钻探深度也不过只有十多公里。因此，地震学是目前人类探测地球深部结构的主要手段，\n许多重大的地球内部发现都是地震学首先研究报道的。","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"IewwHhayzA"}],"key":"NWyKijUx5W"},{"type":"paragraph","position":{"start":{"line":59,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"地震学研究的基本原理包括震源和地震波理论两个部分。前者主要关于震源和地震波的激发，\n后者主要关于地震波如何在地下传播。地震学理论背后的大部分物理知识不过是牛顿第二定律 ","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"key":"x3ufkbOovM"},{"type":"inlineMath","value":"F=ma","position":{"start":{"line":59,"column":1},"end":{"line":59,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>F</mi><mo>=</mo><mi>m</mi><mi>a</mi></mrow><annotation encoding=\"application/x-tex\">F=ma</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.6833em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.13889em;\">F</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.4306em;\"></span><span class=\"mord mathnormal\">ma</span></span></span></span>","key":"mRdAFt6i3K"},{"type":"text","value":"，\n当然实际问题的复杂性促使了地震学家利用复杂的数学技巧以及高性能计算机。一般而言，地震学\n是观测驱动的学科，仪器和数据可用性的改进常常会导致地震学理论和地球内部结构研究的重大突破。","position":{"start":{"line":59,"column":1},"end
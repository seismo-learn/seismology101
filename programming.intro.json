t":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"为什么要学编程？","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"MQydeorIVC"}],"identifier":"id","label":"为什么要学编程？","html_id":"id","implicit":true,"key":"w6M5mLmCWV"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"几乎所有高校在大一都开设了类似《C 语言程序设计》这门课，想必你对 C 语言以及\n编程都已经有了一些了解。编程本质上就是人将某个问题的解决思路写成\n计算机能够读懂的指令，计算机则执行指令帮助人解决问题。","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"h9PKlBDGIo"}],"key":"jrukWIUHWH"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"text","value":"地震学是一门基于观测数据的科学。地震学科研中需要对大量观测数据进行处理和分析，\n并作一些理论计算，因而需要通过编程让计算机辅助完成数据处理或科学计算。","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"za8bgmNnEV"}],"key":"EUQ7K8DH8N"},{"type":"heading","depth":2,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"编程语言有哪些？","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"R8aCyDIDUP"}],"identifier":"id","label":"编程语言有哪些？","html_id":"id-1","implicit":true,"key":"uxtoc6xuLZ"},{"type":"paragraph","position":{"start":{"line":20,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"世界上存在的编程语言有几百个，其中用的比较多的大概有十几个。\n编程语言根据执行方式的差异大致可以分为两大类：","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"nTIiLBc8tf"}],"key":"fFsgjvshWa"},{"type":"definitionList","position":{"start":{"line":23,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"definitionTerm","position":{"start":{"line":23,"column":1},"end":{"line":22,"column":1}},"children":[{"type":"text","value":"编译型语言","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"LIRqTJCeM1"}],"key":"ig2NTF3A5A"},{"type":"definitionDescription","position":{"start":{"line":25,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":27,"column":1}},"children":[{"type":"text","value":"编译型语言是指需要使用特定的","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"KPvcnfMuSI"},{"type":"strong","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"编译器","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"TTPEviEsJU"}],"key":"msT7M3ldOK"},{"type":"text","value":"将源代码编译成在当前系统上可执行的\n二进制文件，再通过运行该二进制文件以执行代码。\nC、C++、Fortran 和 Java 等是常见的编译型语言。","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"kWgf19PNli"}],"key":"DaodXbHzYY"}],"key":"gGQzUFyhWk"},{"type":"definitionTerm","position":{"start":{"line":29,"column":1},"end":{"line":28,"column":1}},"children":[{"type":"text","value":"解释型语言","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"LICTh2qqKQ"}],"key":"Y8d8ToUWqy"},{"type":"definitionDescription","position":{"start":{"line":29,"column":1},"end":{"line":37,"column":1}},"children":[{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":32,"column":1}},"children":[{"type":"text","value":"解释型语言是指需要使用特定的","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"AuLZUhGoMk"},{"type":"strong","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"解释器","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"iLbcv8uou9"}],"key":"BhTMb49UR9"},{"type":"text","value":"读取源代码并立即执行代码。\nPython 和 Matlab 等是常见的解释型语言。","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"cVSVNbUIHw"}],"key":"pj3oRDb0hr"},{"type":"paragraph","position":{"start":{"line":34,"column":1},"end":{"line":36,"column":1}},"children":[{"type":"text","value":"一般将解释型语言编写的源代码称为脚本（script），所以解释型语言也称为","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"xOjnUvv4ha"},{"type":"strong","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"children":[{"type":"text","value":"脚本语言","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"Rc6srFWZoI"}],"key":"fm0gg2JMr1"},{"type":"text","value":"。\n实际上，脚本就是包含一系列指令的文本文件。解释器读取这个文件，\n立即依次执行脚本里的所有命令、函数以及表达式等。","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"UG3k5o0cRy"}],"key":"gClPc06tPd"}],"key":"MjcT6EkLck"}],"key":"AF7U8qNnVl"},{"type":"paragraph","position":{"start":{"line":38,"column":1},"end":{"line":40,"column":1}},"children":[{"type":"text","value":"两种语言都有各自的优缺点。一般而言，编译型语言编写的代码运行速度更快，但需要\n花费更多的时间编写代码，还需要先编译才能使用，因而需要掌握编译方法。解释型语言\n更易于编写，开源的软件库和模块更多，不需要编译即可执行，但一般代码执行速度慢。","position":{"start":{"line":38,"column":1},"end":{"line":38,"column":1}},"key":"UWTwu6Ku5T"}],"key":"TvZD2D4CT2"},{"type":"heading","depth":2,"position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"children":[{"type":"text","value":"我该学习那种编程语言？","position":{"start":{"line":42,"column":1},"end":{"line":42,"column":1}},"key":"C4nuOrYInM"}],"identifier":"id","label":"我该学习那种编程语言？","html_id":"id-2","implicit":true,"key":"YXJf19LCKf"},{"type":"paragraph","position":{"start":{"line":44,"column":1},"end":{"line":47,"column":1}},"children":[{"type":"strong","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"地震学科研工作者需至少掌握一门脚本语言，同时推荐学习一门编译型语言","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"HBbnmEW7Vr"}],"key":"cLb4Sl87Do"},{"type":"text","value":"。对于脚本语言，\n推荐使用目前在地震学领域最流行的 Python 语言，其官方模块、第三方模块和软件包众多，\n基本可以满足日常科研工作需求。而使用哪种编译型语言并不重要，熟悉掌握一门编译型语言，\n其他编译型语言也就可以很快地学会和上手了。","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"AheyyLENeW"}],"key":"fliA7jn8el"},{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":52,"column":1}},"children":[{"type":"text","value":"日常的数据处理和简单的科学计算可以使用脚本语言快速实现，以便迅速上手和开展研究。如果需要\n更高的计算效率，可以使用编译型语言编写代码。因此，完成一个项目往往是同时使用这两类编程语言\n来编写代码。有时候还可以用脚本语言快速、便捷地实现一个任务的一部分，然后调用使用编译型语言\n书写的需求计算效率的另外一部分的代码来加速计算。","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"jQ0rqtrrOr"}],"key":"yjRgDh10TM"},{"type":"paragraph","position":{"start":{"line":54,"column":1},"end":{"line":59,"column":1}},"children":[{"type":"text","value":"需要注意的是，在本教程中我们将 Linux 和 macOS 系统的 Shell 也归为脚本语言。严格说来，\nShell 其实本身只是一个空壳，具有最基本的条件判断和循环功能。借助 Linux 和 macOS 系统的\n命令行工具，如 ","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"TTrEEhGZgv"},{"type":"inlineCode","value":"awk","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"q71aB3Sx3l"},{"type":"text","value":"、","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"F5HlZen19X"},{"type":"inlineCode","value":"sort","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"ztOb5SaMfr"},{"type":"text","value":"、","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"wlgMXalzSt"},{"type":"inlineCode","value":"grep","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"ruPfUtbmjX"},{"type":"text","value":"，其可以用来做日常的数据处理、\n字符串处理等。Shell 脚本一般仅适合用几行就可以搞定的简单程序，更复杂的情况建议使用其他\n脚本语言来完成。我们以一种常见的 Shell 来讲述其基本语法和用途，即 Bash，其他常见的 Shell\n还有 Zsh、csh 等。","position":{"start":{"line":54,"column":1},"end":{"line":54,"column":1}},"key":"xTEddKR1T7"}],"key":"Ul5VvtVXY1"},{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"日常编程除了直接编写代码，往往还需要写 README 文件和记一些笔记，有时还要写代码的参考文档。\n因此，推荐学习一种标记语言以便更简洁、更高效地完成上述事务。推荐学习 Markdown 标记语言。","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"ceyQHOZIrm"}],"key":"os8UbD1mOD"}],"key":"uC84H3Dapp"}],"key":"nJ2uRldL0p"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Linux 常用命令","url":"/computer/commands","group":"计算机基础"},"next":{"title":"编程语言","url":"/programming/languages","group":"编程基础"}}},"domain":"http://localhost:3000"}
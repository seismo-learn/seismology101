":"text","value":"查看 ","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"JjAn7UIF2W"},{"type":"inlineCode","value":"wsl","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"IKHyY0wbxV"},{"type":"text","value":" 命令的完整帮助文档：","position":{"start":{"line":112,"column":1},"end":{"line":112,"column":1}},"key":"gyE3cEu1H8"}],"key":"C16Iqxj4bw"},{"type":"code","lang":"","value":"$ wsl --help","position":{"start":{"line":113,"column":1},"end":{"line":115,"column":1}},"key":"rCzsaY4RiO"},{"type":"paragraph","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"children":[{"type":"text","value":"列出所有已安装的 Linux 发行版的状态：","position":{"start":{"line":117,"column":1},"end":{"line":117,"column":1}},"key":"D4cBcKiQRD"}],"key":"n27kV33eXj"},{"type":"code","lang":"","value":"$ wsl --list","position":{"start":{"line":118,"column":1},"end":{"line":120,"column":1}},"key":"lbVJr0pgeK"},{"type":"paragraph","position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"children":[{"type":"text","value":"检查 WSL 状态：","position":{"start":{"line":122,"column":1},"end":{"line":122,"column":1}},"key":"G3J1ZW7FL9"}],"key":"P1mzyBrxei"},{"type":"code","lang":"","value":"$ wsl --status","position":{"start":{"line":123,"column":1},"end":{"line":125,"column":1}},"key":"d6pxdGeZID"},{"type":"paragraph","position":{"start":{"line":127,"column":1},"end":{"line":127,"column":1}},"children":[{"type":"text","value":"停止正在运行的 Linux 发行版：","position":{"start":{"line":127,"column":1},"end":{"line":127,"column":1}},"key":"Unym88VZm9"}],"key":"tP6Y7joVws"},{"type":"code","lang":"","value":"$ wsl --terminate Ubuntu","position":{"start":{"line":128,"column":1},"end":{"line":130,"column":1}},"key":"n0tmxDxAPf"},{"type":"paragraph","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"children":[{"type":"text","value":"注销并卸载某个 Linux 发行版：","position":{"start":{"line":132,"column":1},"end":{"line":132,"column":1}},"key":"UnvcKDcodp"}],"key":"qPftUqGh0x"},{"type":"code","lang":"","value":"$ wsl --unregister Ubuntu","position":{"start":{"line":133,"column":1},"end":{"line":135,"column":1}},"key":"KkFVKlPJ6X"},{"type":"details","children":[{"type":"summary","children":[{"type":"text","value":"将 WSL 从 C 盘移动到其它盘","position":{"start":{"line":137,"column":1},"end":{"line":137,"column":1}},"key":"vAPFZDrPR1"}],"key":"Jkqv5GfNE4"},{"type":"paragraph","position":{"start":{"line":139,"column":1},"end":{"line":140,"column":1}},"children":[{"type":"text","value":"这一节仅适用于 C 盘空间不足，或明确希望将 WSL 发行版存放到其它磁盘的读者。\n对于大多数用户而言，这不是必需步骤，可以直接跳过。","position":{"start":{"line":139,"column":1},"end":{"line":139,"column":1}},"key":"yea3rIVOdS"}],"key":"b8CLSDYPRf"},{"type":"paragraph","position":{"start":{"line":142,"column":1},"end":{"line":145,"column":1}},"children":[{"type":"text","value":"开启 WSL 后，Linux 发行版的默认安装位置是 C 盘。为了避免占用 C 盘的大量空间，\n可以将已安装的 Linux 发行版导出备份，再导入还原到其它盘，最后删除 C 盘上的发行版。\n这样做的另一个好处是，导入后 Linux 发行版的数据文件会位于用户指定的目录中，\n便于管理和备份。打开 CMD，执行如下命令:","position":{"start":{"line":142,"column":1},"end":{"line":142,"column":1}},"key":"px1GzI8k59"}],"key":"hFdGDjwzpg"},{"type":"code","lang":"","value":"# 导出 Linux 发行版，可做为备份\n# 在 D 盘中新建备份目录，命名为 WSLBAK\n$ mkdir D:\\WSLBAK\n# 导出到备份目录下，命名为 backup.tar\n$ wsl --export Ubuntu D:\\WSLBAK\\backup.tar\n# 导入并还原之前备份的 Linux 发行版\n# 此例中选择在 D 盘中新建还原目录，命名为 UbuntuData\n$ mkdir D:\\WSLDIR\\UbuntuData\n# 导入并还原之前的备份，将此发行版命名为 UbuntuData\n$ wsl --import UbuntuData D:\\WSLDIR\\UbuntuData D:\\WSLBAK\\backup.tar\n# 删除 C 盘里名为 Ubuntu 的发行版，以释放 C 盘空间\n$ wsl --unregister Ubuntu","position":{"start":{"line":146,"column":1},"end":{"line":159,"column":1}},"key":"bEBAlN0URh"}],"key":"yZHg3VgIxo"},{"type":"heading","depth":2,"position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"children":[{"type":"text","value":"跨系统文件互访","position":{"start":{"line":162,"column":1},"end":{"line":162,"column":1}},"key":"THi570ybZH"}],"identifier":"id","label":"跨系统文件互访","html_id":"id-2","implicit":true,"key":"b0ZCN0RKrl"},{"type":"paragraph","position":{"start":{"line":164,"column":1},"end":{"line":167,"column":1}},"children":[{"type":"text","value":"WSL 有 WSL1 和 WSL2 两个版本。WSL2 是安装 Linux 发行版时的默认版本，通常也是更推荐的选择。\n但在跨系统访问文件方面（即在 Windows 下访问 WSL 中的文件或在 WSL 下访问 Windows 中的文件），\nWSL1 在某些场景下可能比 WSL2 更快。因而，在使用 WSL2 时，建议尽量将处理的文件放在 WSL 中，\n以避免跨系统访问文件。","position":{"start":{"line":164,"column":1},"end":{"line":164,"column":1}},"key":"s3Wyb5bTBL"}],"key":"AYJjfzyruv"},{"type":"paragraph","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"children":[{"type":"text","value":"对于有经常跨系统操作文件的需求，可以使用如下命令将 Linux 发行版（假定名为 Ubuntu）从 WSL2 转换为 WSL1：","position":{"start":{"line":169,"column":1},"end":{"line":169,"column":1}},"key":"bB3tkozol2"}],"key":"UY5qttlTit"},{"type":"code","lang":"","value":"$ wsl --set-version Ubuntu 1","position":{"start":{"line":170,"column":1},"end":{"line":172,"column":1}},"key":"ekD35bARBm"},{"type":"paragraph","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"children":[{"type":"text","value":"同样的，也可以使用如下命令将 Linux 发行版（假定名为 Ubuntu）从 WSL1 转换为 WSL2：","position":{"start":{"line":173,"column":1},"end":{"line":173,"column":1}},"key":"PX0szBo0nk"}],"key":"Z8tJlOyI9R"},{"type":"code","lang":"","value":"$ wsl --set-version Ubuntu 2","position":{"start":{"line":174,"column":1},"end":{"line":176,"column":1}},"key":"wXBAV86syL"},{"type":"heading","depth":3,"position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"children":[{"type":"text","value":"WSL 访问 Windows","position":{"start":{"line":178,"column":1},"end":{"line":178,"column":1}},"key":"zyAKIQKWnx"}],"identifier":"wsl-windows","label":"WSL 访问 Windows","html_id":"wsl-windows","implicit":true,"key":"XH2TM8m7Rc"},{"type":"paragraph","position":{"start":{"line":180,"column":1},"end":{"line":181,"column":1}},"children":[{"type":"text","value":"Windows 系统的硬盘挂载在 WSL 的 ","position":{"start":{"line":180,"column":1},"end":{"line":180,"colu
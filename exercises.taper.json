":1},"end":{"line":102,"column":1}},"key":"ME88JtwPeD"},{"type":"inlineCode","value":"max_percentage=0.1","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"Nzn5Gsf7yU"},{"type":"text","value":"）：","position":{"start":{"line":102,"column":1},"end":{"line":102,"column":1}},"key":"bPIWCqtHpv"}],"key":"n4bcIHVDMQ"}],"key":"j0cTkuLhAd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"tr.taper(max_percentage=0.1, type=\"hann\")","key":"bnwykheUPj"},{"type":"outputs","id":"AwDKuCWttAZobXI26wpvi","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":4,"metadata":{},"data":{"text/plain":{"content":"IU.ANMO.00.BHZ | 2022-09-22T06:24:40.019538Z - 2022-09-22T06:29:39.994538Z | 40.0 Hz, 12000 samples","content_type":"text/plain"}}},"key":"jAcfMsts01"}],"key":"Fps3pkxZrk"}],"key":"F2sIakmmAl"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":109,"column":1},"end":{"line":110,"column":1}},"children":[{"type":"text","value":"下图演示了尖灭操作的效果：黑色和红色分别为尖灭操作前后的波形。可以看到，原始波形（黑）\n在截断处存在“硬边界”，而尖灭后（红）两端平滑过渡至零，能有效抑制频谱泄漏。","position":{"start":{"line":109,"column":1},"end":{"line":109,"column":1}},"key":"pBYJU8HfRY"}],"key":"g2z7cBuxNf"}],"key":"zxmpmeP8ko"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plt.figure(figsize = (10, 4))\nplt.plot(tr_origin.times(), tr_origin.data, 'k-', label='Original')\nplt.plot(tr.times(), tr.data, 'r-', label='Tapered', alpha=0.85)\nplt.xlabel('Time (s)')\nplt.ylabel('Amplitude')\nplt.title('Tapering Comparison')\nplt.legend()\nplt.show()","key":"bOtrrTfH9F"},{"type":"outputs","id":"IQD3jQHDNoC3lCXfTxO2g","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1000x400 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"i
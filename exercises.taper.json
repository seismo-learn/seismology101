n class=\"mclose\">)</span></span></span></span>","key":"ljKmG4RujO"},{"type":"text","value":" 在信号首尾逐渐从 0 过渡到 1，并在中间区域保持为 1，实现波形的尖灭。","position":{"start":{"line":29,"column":1},"end":{"line":29,"column":1}},"key":"F41mIFvkPN"}],"key":"oUfAlyRAHN"},{"type":"paragraph","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"children":[{"type":"text","value":"下图比较了两种常用的尖灭窗：余弦窗 (cosine) 与 Hanning 窗 (hann)。本示例中，两端各 5% 长度用于平滑渐入/渐出，中间部分保持幅度 1。","position":{"start":{"line":31,"column":1},"end":{"line":31,"column":1}},"key":"xN3xCnR2fO"}],"key":"Xl8cTe6NrG"}],"key":"V5FaC47CNL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom obspy.signal.invsim import cosine_taper  # ObsPy 余弦尖灭\n\n# 参数设置\nnpts = 1000\np = 0.05  # 两端 5%\n\n# 余弦尖灭窗\nwin_cos = cosine_taper(npts, p=p)\n\n# Hanning 窗（构造两端平滑、中间平坦）\nwin_han = np.ones(npts)\nedge = int(p * npts)\nhan_full = np.hanning(2 * edge)\nwin_han[:edge] = han_full[:edge]\nwin_han[-edge:] = han_full[-edge:]\n\nx = np.linspace(0, 1, npts)\nplt.figure(figsize=(9, 4))\nplt.plot(x, win_cos, 'r-', lw=2, label=f'Cosine (p={p})')\nplt.plot(x, win_han, 'b--', lw=2, label=f'Hanning (p={p})')\nplt.xlabel('Normalized Time')\nplt.ylabel('Amplitude')\nplt.title('Cosine vs Hanning Taper Windows')\nplt.legend()\nplt.show()","visibility":"hide","key":"z6qc2jH5GI"},{"type":"outputs","id":"Npu_qEE4HekPERMWY-RwY","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 900x400 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"2e252d6fb595fcd0ad2b05335048f7d0","path":"/seismology101/build/2e252d6fb595fcd0ad2b05335048f7d0.png"}}},"key":"TSlGacG9CJ"}],"visibility":"show","key":"oVyI3DT6ip"}],"data":{"tags":[]},"visibility":"show","key":"VjrlUYQPWC"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"children":[{"type":"text","value":"我们以前一节使用的 2022 年 9 月 22 日墨西哥 Mw 6.8 地震在 ANMO 台站的波形为例。","position":{"start":{"line":64,"column":1},"end":{"line":64,"column":1}},"key":"vOoM90vSJq"}],"key":"sKFiEbx13I"}],"key":"u62VSIuiA1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from obspy import UTCDateTime\nfrom obspy.clients.fdsn import Client\nimport matplotlib.pyplot as plt\n\nclient = Client(\"IRIS\") \n\n# 下载 2022 年墨西哥 Mw 6.8 级地震在 ANMO 台站的波形数据(选择 400–700 s 时间窗)\norigin_time = UTCDateTime(\"2022-09-22T06:18:00\")\nstarttime = origin_time + 400\nendtime = origin_time + 700\nst = client.get_waveforms(\n    network=\"IU\",\n    station=\"ANMO\", \n    location=\"00\", \n    channel=\"BHZ\",\n    starttime=starttime, \n    endtime=endtime,\n)\nst.plot();","key":"lf4cc52DoO"},{"type":"outputs","id":"-dFf3ilfXtNlfHehl2XKH","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/home/runner/micromamba/envs/seismo-learn/lib/python3.14/site-packages/obspy/clients/fdsn/client.py:251: ObsPyDeprecationWarning: IRIS is now EarthScope, please consider changing the FDSN client short URL to 'EARTHSCOPE'.\n  warnings.warn(msg, ObsPyDeprecationWarning)\n"},"key":"h6L2nJ6bSg"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x250 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"57ae31b1d4c7d750b7eae23a2793d8c5","path":"/seismology101/build/57ae31b1d4c7d750b7eae23a2793d8c5.png"}}},"key":"LQerMsjW8I"}],"key":"JuhMFFDmLk"}],"key":"YrnYMcLbBg"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":88,"column":1},"end":{"line":88,"column":1}},"children":[{"type":"text","value":"进行尖灭处理之前，通常先进行去均值、去线性趋势。","position":{"start":{"line":88,"column":1},"end":{"line":
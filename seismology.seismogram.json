:[{"type":"text","value":"体波和面波的波形和传播路径实例。\n引自《[An Introduction to Seismology, Earthquakes, and Earth Structure]》\n图 1.1-3。","position":{"start":{"line":34,"column":1},"end":{"line":34,"column":1}},"key":"Uf2xf2Aqay"}],"key":"iAR9qH5mod"}],"key":"bC6WwvyyYR"}],"enumerator":"1","key":"YNIOibM4hm"}],"key":"eeVsXdGEAf"}],"key":"GYlEgrdoNK"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"地震震相","url":"/seismology/seismic-phase","group":"地震学基础"},"next":{"title":"地震仪","url":"/seismology/seismograph","group":"地震学基础"}}},"domain":"http://localhost:3000"}
ulx2QoXG"},{"type":"heading","depth":2,"position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"text","value":"Time Machine","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"P4ZT4qOi2x"}],"identifier":"time-machine","label":"Time Machine","html_id":"time-machine","implicit":true,"key":"nX3wn4nLuF"},{"type":"paragraph","position":{"start":{"line":11,"column":1},"end":{"line":13,"column":1}},"children":[{"type":"text","value":"macOS 下最好用的备份工具当属 Time Machine（时间机器），其可以增量备份 macOS 下的文件，\n能恢复到之前任意备份时刻的状态，并且操作简单。当然也可以使用 ","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"aJUFbkg2NK"},{"type":"inlineCode","value":"rsync","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"UuJExZBXKJ"},{"type":"text","value":" 命令进行备份，\n与 Linux 下相同。推荐使用 Time Machine 进行备份。","position":{"start":{"line":11,"column":1},"end":{"line":11,"column":1}},"key":"CoHtmXOF6U"}],"key":"H3iVf8IJ1Q"},{"type":"paragraph","position":{"start":{"line":15,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"text","value":"首先插入一块备用硬盘，按下 ","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"RDSf5Abek2"},{"type":"keyboard","children":[{"type":"text","value":"Command","key":"OMoN9l6k6x"}],"key":"x3xUSUA3r9"},{"type":"text","value":" + ","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"CuSdjweC5h"},{"type":"keyboard","children":[{"type":"text","value":"空格","key":"rdHHS1NGuH"}],"key":"TQ0suhdKCH"},{"type":"text","value":"，搜索“Disk Utility”并按下\n","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"Ly86Wvmxuu"},{"type":"keyboard","children":[{"type":"text","value":"Enter","key":"gdTt5ZLsBN"}],"key":"kaQk6YhTMJ"},{"type":"text","value":" 键以打开磁盘工具。将移动硬盘格式化成 APFS（加密）格式，这也是 macOS Big Sur（11.x）\n的默认格式。读者可以根据自身情况选择分区大小，推荐至少是 macOS 本身硬盘空间的两倍。","position":{"start":{"line":15,"column":1},"end":{"line":15,"column":1}},"key":"vU9I1MTfiz"}],"key":"jn8IMD4Vaw"},{"type":"paragraph","position":{"start":{"line":19,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"点击左上角的 Apple 图标，在“系统偏好设置”中，打开“时间机器”。选中“在菜单栏中显示时间机器”。\n点击“选择备份磁盘”，从可用磁盘列表中选择之前格式化的硬盘分区，然后选择“使用磁盘”即可。\n时间机器会立即开始备份。首次备份可能需要很长时间，之后只会同步有改动的文件。下次插入备份硬盘，\n直接从菜单栏的时间机器菜单中选择“立即备份”即开始增量备份。可以选择“进入时间机器”，查看备份内容。\n如需还原备份文件，请参考官方支持","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"wV5r0xFSvF"},{"type":"link","url":"https://support.apple.com/zh-cn/HT203981","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"text","value":"从备份恢复 Mac","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"d0NdKkxg7U"}],"urlSource":"https://support.apple.com/zh-cn/HT203981","key":"I3CVUDfBEm"},{"type":"text","value":"。","position":{"start":{"line":19,"column":1},"end":{"line":19,"column":1}},"key":"v66xoEIFgI"}],"key":"rdcP5MwSa2"}],"key":"wBLJstiMiR"}],"key":"XVBP4VG5I7"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Linux 数据备份","url":"/best-practices/backup-linux","group":"实践经验"},"next":{"title":"Windows 数据备份","url":"/best-practices/backup-windows","group":"实践经验"}}},"domain":"http://localhost:3000"}
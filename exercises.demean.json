nfrom obspy.clients.fdsn import Client\nimport matplotlib.pyplot as plt\n\nclient = Client(\"IRIS\") \n\n# 下载 2022 年墨西哥 Mw 6.8 级地震在 ANMO 台站的波形数据\nstarttime = UTCDateTime(\"2022-09-22T06:18:00\")\nendtime = starttime + 720  # 下载 12 分钟数据\nst = client.get_waveforms(\n    network=\"IU\",\n    station=\"ANMO\", \n    location=\"00\", \n    channel=\"BHZ\",\n    starttime=starttime, \n    endtime=endtime,\n)\nst.plot();","key":"vXaptSUSiw"},{"type":"outputs","id":"wAxNyVol4ZtLQR6WUEOhO","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/home/runner/micromamba/envs/seismo-learn/lib/python3.14/site-packages/obspy/clients/fdsn/client.py:251: ObsPyDeprecationWarning: IRIS is now EarthScope, please consider changing the FDSN client short URL to 'EARTHSCOPE'.\n  warnings.warn(msg, ObsPyDeprecationWarning)\n"},"key":"dQAVWA3kww"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x250 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"7f345d0e4c9913ea4646ff1a7975c953","path":"/seismology101/build/7f345d0e4c9913ea4646ff1a7975c953.png"}}},"key":"jKbFjBbTmf"}],"key":"xWteZLc7JW"}],"key":"WjrGvMGFNF"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"ObsPy 提供了 ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"SRvOJuwGEz"},{"type":"inlineCode","value":"obspy.core.trace.Trace.detrend","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"I4fy4S3sm4"},{"type":"text","value":" 方法可以实现去均值操作。","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"rFqqmupO90"}],"key":"wg9NxbW6Cg"}],"key":"c3XUXcj1hh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"tr = st[0]\nprint(f\"Mean value before demean: {tr.data.mean()}\")\n\n# 去均值处理\ntr.detrend(\"demean\")  \n\nprint(f\"Mean value after demean: {tr.data.mean()}\")","key":"TZERhOHXSR"},{"type":"outputs","id":"gtUmtp6A1NLz9F7PKli6z","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Mean value before demean: 1060.4151041666667\nMean value after demean: 4.042198674546348e-12\n"},"key":"eq2LQJuZic"}],"key":"n0ps0VZFQb"}],"key":"cg2RMzMteQ"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"虽然原始波形在视觉上观察不到显著的直流分量，但是去均值（demean）操作成功地\n将原始波形的均值从 1060.42 变为 4.04e-12，表明已经完成了去均值操作。","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"BfeRnoOeH3"}],"key":"mH8s48sO31"}],"key":"OjWqoyIYSG"}],"key":"JC8pgcfF6m"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"数据处理","url":"/exercises/process","group":"地震学实践"},"next":{"title":"去线性趋势","url":"/exercises/detrend","group":"地震学实践"}}},"domain":"http://localhost:3000"}
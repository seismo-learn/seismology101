":"ql1CrCTuf0"}],"key":"iPgBi1LwyZ"}],"key":"KuEXZOboLK"},{"type":"paragraph","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"去均值是从每个数据点中减去所有数据点的平均值（也称直流分量），这一操作旨在消除仪器零点漂移，一般是数据处理的第一步。","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"n8GT7DgtKX"}],"key":"W1WdEJcpOX"},{"type":"paragraph","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"我们以 2022 年 9 月 22 日发生在墨西哥的一个 Mw 6.8 级地震为例，该地震的详细信息见 ","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"EMFWlXyY6s"},{"type":"link","url":"https://earthquake.usgs.gov/earthquakes/eventpage/us7000ia36","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"https://​earthquake​.usgs​.gov​/earthquakes​/eventpage​/us7000ia36","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"DtC0Bv9mRL"}],"urlSource":"https://earthquake.usgs.gov/earthquakes/eventpage/us7000ia36","key":"cyivynQyjZ"},{"type":"text","value":"。","position":{"start":{"line":23,"column":1},"end":{"line":23,"column":1}},"key":"TeqtY0ccIW"}],"key":"MKA2fvDZvI"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":26,"column":1}},"children":[{"type":"text","value":"使用 ObsPy 提供的 ","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"WRh6OcPWsp"},{"type":"inlineCode","value":"Client.get_waveforms() <obspy.clients.fdsn.client.Client.get_waveforms>","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"R2163XTuZ8"},{"type":"text","value":" 方法下载\n该地震在 ANMO 台站的事件波形资料。","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"SB7W3vyZbj"}],"key":"x5uKLWZqGG"}],"key":"DIBWzwMpqF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from obspy import UTCDateTime\nfrom obspy.clients.fdsn import Client\nimport matplotlib.pyplot as plt\n\nclient = Client(\"IRIS\") \n\n# 下载 2022 年墨西哥 Mw 6.8 级地震在 ANMO 台站的波形数据\nstarttime = UTCDateTime(\"2022-09-22T06:18:00\")\nendtime = starttime + 720  # 下载 12 分钟数据\nst = client.get_waveforms(\n    network=\"IU\",\n    station=\"ANMO\", \n    location=\"00\", \n    channel=\"BHZ\",\n    starttime=starttime, \n    endtime=endtime,\n)\nst.plot();","key":"Wk1fQR90BP"},{"type":"outputs","id":"fo8hsD_CO2WFDUl3ALXKt","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/home/runner/micromamba/envs/seismo-learn/lib/python3.14/site-packages/obspy/clients/fdsn/client.py:251: ObsPyDeprecationWarning: IRIS is now EarthScope, please consider changing the FDSN client short URL to 'EARTHSCOPE'.\n  warnings.warn(msg, ObsPyDeprecationWarning)\n"},"key":"UzAQTiRPPh"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x250 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"79d3272a901fe7500c237350bf4ca0ac","path":"/seismology101/build/79d3272a901fe7500c237350bf4ca0ac.png"}}},"key":"jToXIgk8Ym"}],"key":"WURGyQ6K0r"}],"key":"keCQ0pr0R0"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"ObsPy 提供了 ","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"oKXUyaihXj"},{"type":"inlineCode","value":"obspy.core.trace.Trace.detrend","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"xZeJuhWbE6"},{"type":"text","value":" 方法可以实现去均值操作。","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"EuUqGGNBKE"}],"key":"aQOwaCA5Go"}],"key":"LKbnV201Ph"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"tr = st[0]\nprint(f\"Mean value before demean: {tr.data.mean()}\")\n\n# 去均值处理\ntr.detrend(\"demean\")  \n\nprint(f\"Mean value after demean: {tr.data.mean()}\")","key":"THn6u4xPr1"},{"type":"outputs","id":"8NAAJORlkkzNWdutBqZkG","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Mean value before demean: 1060.4151041666667\nMean value after demean: 4.042198674546348e-12\n"},"key":"jNbWADIKk5"}],"key":"QL4i0jDh6U"}],"key":"iS4FxLlIBm"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":62,"column":1}},"children":[{"type":"text","value":"虽然原始波形在视觉上观察不到显著的直流分量，但是去均值（demean）操作成功地\n将原始波形的均值从 1060.42 变为 4.04e-12，表明已经完成了去均值操作。","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"f03iZ6ydgs"}],"key":"HQFvrZsdNE"}],"key":"eWZ2j7Esi9"}],"key":"n2dSTjQHoB"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"数据处理","url":"/exercises/process","group":"地震学实践"},"next":{"title":"去线性趋势","url":"/exercises/detrend","group":"地震学实践"}}},"domain":"http://localhost:3000"}
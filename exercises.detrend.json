{"version":3,"kind":"Notebook","sha256":"b922d5da0fa5b89609f95e0472a8265a1cd0a49ef6b48354ca2732ce08c1cf72","slug":"exercises.detrend","location":"/exercises/detrend.md","dependencies":[],"frontmatter":{"title":"去线性趋势","kernelspec":{"name":"python3","display_name":"Python 3","language":"python"},"jupytext":{"text_representation":{"extension":".md","format_name":"myst","format_version":"0.13","jupytext_version":"1.13.0"}},"content_includes_title":false,"github":"https://github.com/seismo-learn/seismology101","numbering":{"title":{"offset":2}},"source_url":"https://github.com/seismo-learn/seismology101/blob/main/source/exercises/detrend.md","edit_url":"https://github.com/seismo-learn/seismology101/edit/main/source/exercises/detrend.md","exports":[{"format":"md","filename":"detrend.md","url":"/seismology101/build/detrend-1deb38892e8d4baf311485bcc5c7a2db.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":16,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"本节贡献者: {{何星辰}}、{{田冬冬}}、{{姚家园}}","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"JHirjtI1d9"}],"key":"pLpLoc93ET"}],"key":"pRRgTxlCC9"},{"type":"listItem","spread":true,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"最近更新日期: 2025-10-21","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"bbJMslpg7A"}],"key":"vfuquWACMk"}],"key":"fktfWHgdii"},{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"预计花费时间: 10 分钟","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"LvK1riFmLQ"}],"key":"jm4M9lhU11"}],"key":"D3b3Xg9m2X"}],"key":"mRa70hnT82"},{"type":"thematicBreak","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"WzR8LbTfby"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"去线性趋势是指计算出一条最能拟合整个波形数据的直线（即趋势线），并从每个数据点中减去该直线对应的值，\n使波形围绕稳定的零基线振动。此操作用于去除由温度变化或地壳形变等因素造成的缓慢漂移与基线偏移。","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"VnbAVMjRI9"}],"key":"msfOwlA0IR"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"我们以前一节使用的 2022 年 9 月 22 日墨西哥 Mw 6.8 地震在 ANMO 台站的波形为例。","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"a3tI2sl5l0"}],"key":"XpvngNklOb"}],"key":"IxlBYOKp96"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from obspy import UTCDateTime\nfrom obspy.clients.fdsn import Client\nimport matplotlib.pyplot as plt\nfrom numpy.polynomial import polynomial as P\n\nclient = Client(\"IRIS\") \n\n# 下载 2022 年墨西哥 Mw 6.8 级地震在 ANMO 台站的波形数据\nstarttime = UTCDateTime(\"2022-09-22T06:18:00\")\nendtime = starttime + 720  # 下载 12 分钟数据\nst = client.get_waveforms(\n    network=\"IU\",\n    station=\"ANMO\", \n    location=\"00\", \n    channel=\"BHZ\",\n    starttime=starttime, \n    endtime=endtime,\n)\nst.plot();","key":"Mqi2sBaUdX"},{"type":"outputs","id":"ClsubyzPgmJnjZdjDHHHZ","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/home/runner/micromamba/envs/seismo-learn/lib/python3.14/site-packages/obspy/clients/fdsn/client.py:251: ObsPyDeprecationWarning: IRIS is now EarthScope, please consider changing the FDSN client short URL to 'EARTHSCOPE'.\n  warnings.warn(msg, ObsPyDeprecationWarning)\n"},"key":"Yc6dNjyIax"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x250 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"7f345d0e4c9913ea4646ff1a7975c953","path":"/seismology101/build/7f345d0e4c9913ea4646ff1a7975c953.png"}}},"key":"bOkJRVvkRQ"}],"key":"qin1xxjgSf"}],"key":"uWn9m2KjF7"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"进行去线性趋势处理之前，通常需要先进行去均值操作。","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"kOhrnAgioU"}],"key":"z4zkV9UmkK"}],"key":"kfX2RsY9eR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"tr = st[0]\n\n# 去均值\ntr.detrend(\"demean\")\n\n# 计算去线性趋势处理前的斜率\nslope_before = P.polyfit(tr.times(), tr.data, deg=1)[1]\nprint(f\"Slope before linear detrend: {slope_before}\")","key":"gXp3t0IJAm"},{"type":"outputs","id":"rkyeMEqsR907JJ0HniBXf","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Slope before linear detrend: -1.153520875022328\n"},"key":"pe3BMVhS99"}],"key":"d82aNtnIEk"}],"key":"pE8mqG47ob"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"ObsPy 提供了 ","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"yajXyKrjxy"},{"type":"inlineCode","value":"obspy.core.trace.Trace.detrend","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"AWy0rjanrW"},{"type":"text","value":" 方法可以实现去线性趋势操作。","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"RLYHzDpwa5"}],"key":"l97rzk0vcU"}],"key":"BhwJbUAOW6"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 去线性趋势\ntr.detrend(\"linear\")\n\n# 计算去线性趋势处理后的斜率\nslope_after = P.polyfit(tr.times(), tr.data, deg=1)[1]\nprint(f\"Slope after linear detrend: {slope_after}\")","key":"lyorGNME9S"},{"type":"outputs","id":"4KTTxWg9pCoN8ZlqKiiQ0","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Slope after linear detrend: 1.734000825199208e-14\n"},"key":"Et10eISpBM"}],"key":"meJ48C9U8g"}],"key":"NN2qvW7x1g"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"可以看到，针对去均值后的波形，其斜率从 -1.15 降至 1.96e-14，说明 detrend 方法已成功校正基线。","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"QyX1JyJtw6"}],"key":"J9EHYBtgQg"}],"key":"ym6xG8SAxB"}],"key":"kbRS9fhaHP"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"去均值","url":"/exercises/demean","group":"地震学实践"},"next":{"title":"波形尖灭","url":"/exercises/taper","group":"地震学实践"}}},"domain":"http://localhost:3000"}
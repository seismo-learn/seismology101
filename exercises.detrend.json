{"version":3,"kind":"Notebook","sha256":"34336cf2385b9d4c2e9f3a0ef9cacec2f486818996555f78dc2121de085a0628","slug":"exercises.detrend","location":"/exercises/detrend.md","dependencies":[],"frontmatter":{"title":"去线性趋势","kernelspec":{"name":"python3","display_name":"Python 3","language":"python"},"jupytext":{"text_representation":{"extension":".md","format_name":"myst","format_version":"0.13","jupytext_version":"1.13.0"}},"content_includes_title":false,"github":"https://github.com/seismo-learn/seismology101","numbering":{"title":{"offset":2}},"source_url":"https://github.com/seismo-learn/seismology101/blob/main/source/exercises/detrend.md","edit_url":"https://github.com/seismo-learn/seismology101/edit/main/source/exercises/detrend.md","exports":[{"format":"md","filename":"detrend.md","url":"/seismology101/build/detrend-144f3843c47a14abad793d4ea4859f8f.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":16,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"本节贡献者: 何星辰、田冬冬、姚家园","position":{"start":{"line":16,"column":1},"end":{"line":16,"column":1}},"key":"AW2jJNT7rr"}],"key":"DgXribwnyN"}],"key":"wKPWimKtX7"},{"type":"listItem","spread":true,"position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"最近更新日期: 2025-10-21","position":{"start":{"line":17,"column":1},"end":{"line":17,"column":1}},"key":"Z6PGcvQATT"}],"key":"nzgyRD8EJu"}],"key":"Fwah1Q35Wd"},{"type":"listItem","spread":true,"position":{"start":{"line":18,"column":1},"end":{"line":19,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"预计花费时间: 10 分钟","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"NhGHuDEbRC"}],"key":"bf1XP5xxsm"}],"key":"wqbCmPkSpz"}],"key":"Wx7lWVP3xg"},{"type":"thematicBreak","position":{"start":{"line":20,"column":1},"end":{"line":20,"column":1}},"key":"gnIQQSqoj9"},{"type":"paragraph","position":{"start":{"line":22,"column":1},"end":{"line":23,"column":1}},"children":[{"type":"text","value":"去线性趋势是指计算出一条最能拟合整个波形数据的直线（即趋势线），并从每个数据点中减去该直线对应的值，\n使波形围绕稳定的零基线振动。此操作用于去除由温度变化或地壳形变等因素造成的缓慢漂移与基线偏移。","position":{"start":{"line":22,"column":1},"end":{"line":22,"column":1}},"key":"LC3Psr3WKx"}],"key":"buwScbrfgF"},{"type":"paragraph","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"children":[{"type":"text","value":"我们以前一节使用的 2022 年 9 月 22 日墨西哥 Mw 6.8 地震在 ANMO 台站的波形为例。","position":{"start":{"line":25,"column":1},"end":{"line":25,"column":1}},"key":"kqXSh9nVZV"}],"key":"flaAX0nmXS"}],"key":"bvf52IGaMd"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from obspy import UTCDateTime\nfrom obspy.clients.fdsn import Client\nimport matplotlib.pyplot as plt\nfrom numpy.polynomial import polynomial as P\n\nclient = Client(\"IRIS\") \n\n# 下载 2022 年墨西哥 Mw 6.8 级地震在 ANMO 台站的波形数据\nstarttime = UTCDateTime(\"2022-09-22T06:18:00\")\nendtime = starttime + 720  # 下载 12 分钟数据\nst = client.get_waveforms(\n    network=\"IU\",\n    station=\"ANMO\", \n    location=\"00\", \n    channel=\"BHZ\",\n    starttime=starttime, \n    endtime=endtime,\n)\nst.plot();","key":"RO0tyTNDaE"},{"type":"outputs","id":"x3vsfUZ6xROK6F5M0OzKG","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"/home/runner/micromamba/envs/seismo-learn/lib/python3.14/site-packages/obspy/clients/fdsn/client.py:251: ObsPyDeprecationWarning: IRIS is now EarthScope, please consider changing the FDSN client short URL to 'EARTHSCOPE'.\n  warnings.warn(msg, ObsPyDeprecationWarning)\n"},"key":"ZKtGUgqiIF"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 800x250 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"79d3272a901fe7500c237350bf4ca0ac","path":"/seismology101/build/79d3272a901fe7500c237350bf4ca0ac.png"}}},"key":"jo7NwhXLbG"}],"key":"OQ5hh4q1hc"}],"key":"TAIzjSnxhJ"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"children":[{"type":"text","value":"进行去线性趋势处理之前，通常需要先进行去均值操作。","position":{"start":{"line":49,"column":1},"end":{"line":49,"column":1}},"key":"nWvNGfmd4N"}],"key":"JZG6JzvDAC"}],"key":"KmCcQCv6mW"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"tr = st[0]\n\n# 去均值\ntr.detrend(\"demean\")\n\n# 计算去线性趋势处理前的斜率\nslope_before = P.polyfit(tr.times(), tr.data, deg=1)[1]\nprint(f\"Slope before linear detrend: {slope_before}\")","key":"ncihJLIqS6"},{"type":"outputs","id":"kjlH7q2K9mCsU1_uhrh4r","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Slope before linear detrend: -1.153520875022328\n"},"key":"tc3iA9H8vM"}],"key":"PdXlTxPQuZ"}],"key":"SqR1XjEuES"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"children":[{"type":"text","value":"ObsPy 提供了 ","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"HKIclIskyX"},{"type":"inlineCode","value":"obspy.core.trace.Trace.detrend","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"u1xjSokjD1"},{"type":"text","value":" 方法可以实现去线性趋势操作。","position":{"start":{"line":61,"column":1},"end":{"line":61,"column":1}},"key":"E1KsWQfq4i"}],"key":"lbPhzwiSb4"}],"key":"B7VH0aD6oA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 去线性趋势\ntr.detrend(\"linear\")\n\n# 计算去线性趋势处理后的斜率\nslope_after = P.polyfit(tr.times(), tr.data, deg=1)[1]\nprint(f\"Slope after linear detrend: {slope_after}\")","key":"oXYPpSVZrw"},{"type":"outputs","id":"MQUe_wuVMLza4Rgwuc8aA","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"Slope after linear detrend: 1.734000825199208e-14\n"},"key":"U3Z1Jx1KSu"}],"key":"FCjFmueXFZ"}],"key":"gMjsnriXLK"},{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"可以看到，针对去均值后的波形，其斜率从 -1.15 降至 1.96e-14，说明 detrend 方法已成功校正基线。","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"xRCZKluAat"}],"key":"ycVxeMWEyu"}],"key":"dbWb1xoZos"}],"key":"rZN4G5prJf"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"去均值","url":"/exercises/demean","group":"地震学实践"},"next":{"title":"波形尖灭","url":"/exercises/taper","group":"地震学实践"}}},"domain":"http://localhost:3000"}